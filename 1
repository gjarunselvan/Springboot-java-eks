#!/bin/bash

echo "======================================"
echo "NUVEPRO FINAL LAB VALIDATION"
echo "======================================"

echo ""
echo "1. EC2 INSTANCE"

INSTANCE_TYPE=$(curl -s http://169.254.169.254/latest/meta-data/instance-type)

echo "INSTANCE TYPE = $INSTANCE_TYPE"

if [ "$INSTANCE_TYPE" = "t3.small" ]; then
echo "PASS"
else
echo "FAIL"
fi

echo ""
echo "2. IAM ROLE"

ROLE=$(curl -s http://169.254.169.254/latest/meta-data/iam/security-credentials/)

echo "ROLE = $ROLE"

if [ "$ROLE" = "ec2-eks-role" ]; then
echo "PASS"
else
echo "FAIL"
fi

echo ""
echo "3. JAVA"
java -version >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "4. AWS CLI"
aws --version >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "5. DOCKER"
docker --version >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "6. KUBECTL"
kubectl version --client >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "7. EKSCTL"
eksctl version >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "8. JENKINS"
systemctl is-active jenkins >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "9. JENKINS USER"

id jenkins >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "10. DOCKER GROUP"

groups jenkins | grep docker >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "11. DOCKER VOLUME"

sudo docker volume inspect jenkins_data >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "12. DOCKER NETWORK"

sudo docker network inspect jenkins_network >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "13. ECR REPOSITORY"

aws ecr describe-repositories 
--repository-names springboot-jenkins-ecr-repo 
--region us-east-2 >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "14. EKS CLUSTER"

aws eks describe-cluster 
--name jenkins-cluster 
--region us-east-2 >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "15. NODEGROUP"

aws eks describe-nodegroup 
--cluster-name jenkins-cluster 
--nodegroup-name jenkins-nodegroup 
--region us-east-2 >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "16. K8S NODES"

kubectl get nodes >/dev/null 2>&1 && echo PASS || echo FAIL

echo ""
echo "17. ECR IMAGE"

aws ecr list-images 
--repository-name springboot-jenkins-ecr-repo 
--region us-east-2

echo ""
echo "18. SPRINGBOOT DEPLOYMENT"

kubectl get deployment springboot-app-sample

echo ""
echo "19. LOADBALANCER SERVICE"

kubectl get svc springboot-app

echo ""
echo "======================================"
echo "DONE"
echo "======================================"
