#!/bin/bash

echo "======================================"
echo "GO TO PROJECT"
echo "======================================"

cd ~/springboot-jenkins-eks || exit 1

echo ""
echo "CURRENT PATH"
pwd

echo ""
echo "PROJECT FILES"
ls -ltr

echo ""
echo "CHECK DOCKERFILE"
ls Dockerfile

echo ""
echo "BUILD IMAGE"
docker build -t springboot-app .

echo ""
echo "VERIFY IMAGE"
docker images | grep springboot

echo ""
echo "LOGIN TO ECR"
aws ecr get-login-password --region us-east-2 | \
docker login \
--username AWS \
--password-stdin \
761018881666.dkr.ecr.us-east-2.amazonaws.com

echo ""
echo "TAG IMAGE"
docker tag springboot-app:latest \
761018881666.dkr.ecr.us-east-2.amazonaws.com/springboot-jenkins-ecr-repo:latest

echo ""
echo "PUSH IMAGE"
docker push \
761018881666.dkr.ecr.us-east-2.amazonaws.com/springboot-jenkins-ecr-repo:latest

echo ""
echo "RESTART DEPLOYMENT"
kubectl rollout restart deployment springboot-app

sleep 20

echo ""
echo "PODS"
kubectl get pods -o wide

echo ""
echo "SERVICE"
kubectl get svc

echo ""
echo "DONE"
