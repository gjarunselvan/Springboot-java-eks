#!/bin/bash

echo "=================================="
echo "JENKINS + DOCKER VALIDATION"
echo "=================================="

echo ""
echo "1. JENKINS USER"
id jenkins

echo ""
echo "2. JENKINS GROUPS"
groups jenkins

echo ""
echo "3. DOCKER SOCKET"
ls -l /var/run/docker.sock

echo ""
echo "4. JENKINS CAN ACCESS DOCKER"
sudo su - jenkins -c "docker ps"

if [ $? -eq 0 ]; then
    echo ""
    echo "PASS - Jenkins user can access Docker"
else
    echo ""
    echo "FAIL - Jenkins user cannot access Docker"
fi

echo ""
echo "5. WHOAMI AS JENKINS"
sudo su - jenkins -c "whoami"

echo ""
echo "=================================="
echo "EXPECTED"
echo "=================================="
echo "whoami = jenkins"
echo "docker ps = works"
echo "jenkins in docker group"
