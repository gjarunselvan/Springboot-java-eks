#!/bin/bash

echo "=================================="
echo "FULL JENKINS RESTART"
echo "=================================="

pkill -9 -f jenkins.war || true

sleep 5

echo ""
echo "VERIFY UBUNTU GROUPS"
id ubuntu

echo ""
echo "VERIFY DOCKER"
docker ps

echo ""
echo "START JENKINS"

nohup java -jar /home/ubuntu/jenkins/jenkins.war \
--httpPort=8080 \
> /home/ubuntu/jenkins/jenkins.log 2>&1 &

echo ""
echo "WAIT 30 SECONDS"
sleep 30

echo ""
echo "VERIFY PROCESS"
ps -ef | grep jenkins.war | grep -v grep

echo ""
echo "VERIFY PORT"
ss -tulpn | grep 8080

echo ""
echo "VERIFY WEB"
curl -I http://localhost:8080 | head -5

echo ""
echo "VERIFY PROCESS GROUPS"
PID=$(pgrep -f jenkins.war | head -1)

ps -o user,pid,cmd -p $PID

echo ""
echo "=================================="
echo "READY"
echo "=================================="
echo "1. Logout Jenkins"
echo "2. Close browser"
echo "3. Open Jenkins again"
echo "4. Login"
echo "5. Build Now"
