#!/bin/bash

echo "=================================="
echo "EC2 + IAM VALIDATION"
echo "=================================="

TOKEN=$(curl -s -X PUT 
"http://169.254.169.254/latest/api/token" 
-H "X-aws-ec2-metadata-token-ttl-seconds: 21600")

echo ""
echo "INSTANCE ID"
curl -s 
-H "X-aws-ec2-metadata-token: $TOKEN" 
http://169.254.169.254/latest/meta-data/instance-id

echo ""
echo ""
echo "INSTANCE TYPE"
curl -s 
-H "X-aws-ec2-metadata-token: $TOKEN" 
http://169.254.169.254/latest/meta-data/instance-type

echo ""
echo ""
echo "IAM ROLE"
curl -s 
-H "X-aws-ec2-metadata-token: $TOKEN" 
http://169.254.169.254/latest/meta-data/iam/security-credentials/

echo ""
echo ""
echo "AWS IDENTITY"
aws sts get-caller-identity

echo ""
echo "AWS ARN"
aws sts get-caller-identity 
--query Arn 
--output text

echo ""
echo "=================================="
echo "RESULT"
echo "=================================="

TYPE=$(curl -s 
-H "X-aws-ec2-metadata-token: $TOKEN" 
http://169.254.169.254/latest/meta-data/instance-type)

ROLE=$(curl -s 
-H "X-aws-ec2-metadata-token: $TOKEN" 
http://169.254.169.254/latest/meta-data/iam/security-credentials/)

if [ "$TYPE" = "t3.small" ]; then
echo "EC2 CHECK = PASS"
else
echo "EC2 CHECK = FAIL ($TYPE)"
fi

if [ ! -z "$ROLE" ]; then
echo "IAM ROLE CHECK = PASS ($ROLE)"
else
echo "IAM ROLE CHECK = FAIL"
fi
