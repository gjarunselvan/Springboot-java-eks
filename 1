#!/bin/bash

echo "======================================"
echo "ECR IMAGES"
echo "======================================"

aws ecr list-images \
--repository-name springboot-jenkins-ecr-repo \
--region us-east-2

echo ""
echo "======================================"
echo "DEPLOYMENTS"
echo "======================================"

kubectl get deployments

echo ""
echo "======================================"
echo "PODS"
echo "======================================"

kubectl get pods -o wide

echo ""
echo "======================================"
echo "SERVICES"
echo "======================================"

kubectl get svc

echo ""
echo "======================================"
echo "NODES"
echo "======================================"

kubectl get nodes -o wide

echo ""
echo "======================================"
echo "JENKINS STATUS"
echo "======================================"

sudo systemctl is-active jenkins

echo ""
echo "======================================"
echo "DOCKER STATUS"
echo "======================================"

sudo systemctl is-active docker

echo ""
echo "======================================"
echo "DONE"
echo "======================================"
