#!/bin/bash

echo "======================================"
echo "STEP 1 - BUILD DOCKER IMAGE"
echo "======================================"

docker build -t springboot-app .

echo ""
echo "======================================"
echo "STEP 2 - LOGIN TO ECR"
echo "======================================"

aws ecr get-login-password --region us-east-2 | \
docker login \
--username AWS \
--password-stdin \
761018881666.dkr.ecr.us-east-2.amazonaws.com

echo ""
echo "======================================"
echo "STEP 3 - TAG IMAGE"
echo "======================================"

docker tag springboot-app:latest \
761018881666.dkr.ecr.us-east-2.amazonaws.com/springboot-jenkins-ecr-repo:latest

echo ""
echo "======================================"
echo "STEP 4 - PUSH IMAGE"
echo "======================================"

docker push \
761018881666.dkr.ecr.us-east-2.amazonaws.com/springboot-jenkins-ecr-repo:latest

echo ""
echo "======================================"
echo "STEP 5 - CREATE K8S DEPLOYMENT"
echo "======================================"

cat > eks-deploy-k8s.yaml <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: springboot-app
spec:
  replicas: 2
  selector:
    matchLabels:
      app: springboot-app
  template:
    metadata:
      labels:
        app: springboot-app
    spec:
      containers:
      - name: springboot-app
        image: 761018881666.dkr.ecr.us-east-2.amazonaws.com/springboot-jenkins-ecr-repo:latest
        ports:
        - containerPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: springboot-service
spec:
  selector:
    app: springboot-app
  type: LoadBalancer
  ports:
  - port: 80
    targetPort: 8080
EOF

echo ""
echo "======================================"
echo "STEP 6 - DEPLOY TO EKS"
echo "======================================"

kubectl apply -f eks-deploy-k8s.yaml

echo ""
echo "======================================"
echo "STEP 7 - VERIFY"
echo "======================================"

kubectl get nodes

echo ""
kubectl get pods

echo ""
kubectl get svc

echo ""
echo "======================================"
echo "DONE"
echo "======================================"
