#!/bin/bash

echo "=================================="
echo "FIX DOCKER ACCESS"
echo "=================================="

echo ""
echo "1. ADD UBUNTU TO DOCKER GROUP"
sudo usermod -aG docker ubuntu

echo ""
echo "2. VERIFY GROUP MEMBERSHIP"
groups ubuntu

echo ""
echo "3. FIX DOCKER SOCKET"
sudo chown root:docker /var/run/docker.sock
sudo chmod 660 /var/run/docker.sock

echo ""
echo "4. RESTART DOCKER"
sudo systemctl restart docker

echo ""
echo "5. RESTART JENKINS"
pkill -f jenkins.war || true

nohup java -jar ~/jenkins/jenkins.war \
--httpPort=8080 \
> ~/jenkins/jenkins.log 2>&1 &

echo ""
echo "WAITING 30 SECONDS..."
sleep 30

echo ""
echo "6. VERIFY DOCKER"
docker ps

echo ""
echo "7. VERIFY JENKINS"
curl -I http://localhost:8080 | head -5

echo ""
echo "=================================="
echo "DONE"
echo "=================================="
echo "Now go to Jenkins -> Build Now"
