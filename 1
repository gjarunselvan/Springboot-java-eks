#!/bin/bash

echo "=================================="
echo "RUN JENKINS AS JENKINS USER"
echo "=================================="

pkill -9 -f jenkins.war || true

echo ""
echo "CREATE JENKINS HOME"

sudo mkdir -p /home/jenkins/jenkins

sudo cp /home/ubuntu/jenkins/jenkins.war /home/jenkins/jenkins/

sudo chown -R jenkins:jenkins /home/jenkins

echo ""
echo "VERIFY FILE"

ls -lah /home/jenkins/jenkins/

echo ""
echo "START JENKINS"

sudo su - jenkins -c "
nohup java -jar /home/jenkins/jenkins/jenkins.war \
--httpPort=8080 \
> /home/jenkins/jenkins/jenkins.log 2>&1 &
"

echo ""
echo "WAIT 45 SECONDS"
sleep 45

echo ""
echo "PROCESS CHECK"
ps -ef | grep jenkins.war | grep -v grep

echo ""
echo "PORT CHECK"
ss -tulpn | grep 8080

echo ""
echo "WEB CHECK"
curl -I http://localhost:8080 | head -5

echo ""
echo "DOCKER CHECK"
sudo su - jenkins -c "docker ps"

echo ""
echo "VALIDATION"
OWNER=$(ps -eo user,cmd | grep jenkins.war | grep -v grep | awk '{print \$1}')
echo "OWNER=$OWNER"

echo ""
echo "DONE"
