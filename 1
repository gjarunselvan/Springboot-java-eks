#!/bin/bash

echo "=================================="
echo "MOVE JENKINS TO JENKINS USER"
echo "=================================="

echo ""
echo "1. STOP JENKINS"
pkill -9 -f jenkins.war || true

sleep 5

echo ""
echo "2. FIX OWNERSHIP"
sudo chown -R jenkins:jenkins /home/ubuntu/jenkins

echo ""
echo "3. VERIFY JENKINS USER"
id jenkins

echo ""
echo "4. START AS JENKINS USER"

sudo su - jenkins -c "
nohup java -jar /home/ubuntu/jenkins/jenkins.war \
--httpPort=8080 \
> /home/ubuntu/jenkins/jenkins.log 2>&1 &
"

echo ""
echo "WAIT 30 SECONDS..."
sleep 30

echo ""
echo "5. PROCESS CHECK"
ps -ef | grep jenkins.war | grep -v grep

echo ""
echo "6. PORT CHECK"
ss -tulpn | grep 8080

echo ""
echo "7. WEB CHECK"
curl -I http://localhost:8080 | head -5

echo ""
echo "8. DOCKER AS JENKINS"
sudo su - jenkins -c "docker ps"

echo ""
echo "=================================="
echo "VALIDATION"
echo "=================================="

OWNER=$(ps -eo user,cmd | grep jenkins.war | grep -v grep | awk '{print $1}')

echo "PROCESS OWNER = $OWNER"

if [ "$OWNER" = "jenkins" ]; then
    echo "PASS - Jenkins running as jenkins user"
else
    echo "FAIL - Jenkins still not running as jenkins user"
fi

echo ""
echo "=================================="
echo "DONE"
echo "=================================="
