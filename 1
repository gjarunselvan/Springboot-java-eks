#!/bin/bash

echo "=================================="
echo "CREATE JENKINS USER"
echo "=================================="

if id "jenkins" >/dev/null 2>&1; then
    echo "jenkins user already exists"
else
    sudo useradd -m -s /bin/bash jenkins
    echo "jenkins user created"
fi

echo ""
echo "=================================="
echo "ADD TO DOCKER GROUP"
echo "=================================="

sudo usermod -aG docker jenkins

echo ""
echo "=================================="
echo "RESTART DOCKER"
echo "=================================="

sudo systemctl restart docker

echo ""
echo "=================================="
echo "VERIFY USER"
echo "=================================="

id jenkins

echo ""
echo "=================================="
echo "VERIFY DOCKER ACCESS"
echo "=================================="

sudo su - jenkins -c "docker ps"

echo ""
echo "=================================="
echo "RESULT"
echo "=================================="

echo "If docker ps works, Jenkins user is ready."
