cat > fix-docker.sh << 'EOF'
#!/bin/bash

echo "=================================="
echo "DOCKER FIX FOR JENKINS"
echo "=================================="

sudo usermod -aG docker ubuntu
sudo usermod -aG docker jenkins

sudo chown root:docker /var/run/docker.sock
sudo chmod 660 /var/run/docker.sock

sudo systemctl restart docker

echo ""
echo "VERIFY GROUPS"
groups ubuntu
groups jenkins

echo ""
echo "VERIFY DOCKER SOCKET"
ls -l /var/run/docker.sock

echo ""
echo "TEST UBUNTU"
newgrp docker << EONG
docker ps
EONG

echo ""
echo "TEST JENKINS"
sudo su - jenkins -c "docker ps"

echo ""
echo "RESTART JENKINS"
pkill -f jenkins.war || true

nohup java -jar /home/ubuntu/jenkins/jenkins.war \
--httpPort=8080 \
> /home/ubuntu/jenkins/jenkins.log 2>&1 &

sleep 20

echo ""
echo "JENKINS STATUS"
curl -I http://localhost:8080 | head -5

echo ""
echo "DONE - RUN BUILD NOW"
EOF

chmod +x fix-docker.sh
./fix-docker.sh
