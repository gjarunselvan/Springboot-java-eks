#!/bin/bash

REGION="us-east-2"

echo "=================================="
echo "EKS FINAL VALIDATION"
echo "=================================="

echo ""
echo "===== CLUSTER STATUS ====="
aws eks describe-cluster \
--name jenkins-cluster \
--region $REGION \
--query 'cluster.status' \
--output text

echo ""
echo "===== NODEGROUPS ====="
aws eks list-nodegroups \
--cluster-name jenkins-cluster \
--region $REGION

echo ""
echo "===== UPDATE KUBECONFIG ====="
aws eks update-kubeconfig \
--region $REGION \
--name jenkins-cluster

echo ""
echo "===== KUBECTL CONTEXT ====="
kubectl config current-context

echo ""
echo "===== NODES ====="
kubectl get nodes -o wide

echo ""
echo "===== ECR ====="
aws ecr describe-repositories \
--repository-names springboot-jenkins-ecr-repo \
--region $REGION \
--query 'repositories[*].repositoryName' \
--output text

echo ""
echo "===== JENKINS ====="
curl -I http://localhost:8080 | head -5

echo ""
echo "===== DOCKER ====="
docker volume ls | grep jenkins || true
docker network ls | grep jenkins || true

echo ""
echo "=================================="
echo "DONE"
echo "=================================="
