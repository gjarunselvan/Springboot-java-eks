#!/bin/bash

echo "======================================"
echo "NUVEPRO LAB VALIDATION"
echo "======================================"

PASS=0
TOTAL=0

check() {
TOTAL=$((TOTAL+1))
if eval "$1" >/dev/null 2>&1; then
echo "[PASS] $2"
PASS=$((PASS+1))
else
echo "[FAIL] $2"
fi
}

echo ""
echo "1. JAVA"
check "java -version" "Java Installed"

echo ""
echo "2. MAVEN"
check "mvn -version" "Maven Installed"

echo ""
echo "3. AWS CLI"
check "aws --version" "AWS CLI Installed"

echo ""
echo "4. DOCKER"
check "docker --version" "Docker Installed"

echo ""
echo "5. KUBECTL"
check "kubectl version --client" "kubectl Installed"

echo ""
echo "6. EKSCTL"
check "eksctl version" "eksctl Installed"

echo ""
echo "7. JENKINS SERVICE"
check "systemctl is-active --quiet jenkins" "Jenkins Running"

echo ""
echo "8. JENKINS VOLUME"
check "docker volume inspect jenkins_data" "jenkins_data Exists"

echo ""
echo "9. JENKINS NETWORK"
check "docker network inspect jenkins_network" "jenkins_network Exists"

echo ""
echo "10. JENKINS USER"
check "id jenkins" "jenkins User Exists"

echo ""
echo "11. JENKINS IN DOCKER GROUP"
check "groups jenkins | grep docker" "jenkins in docker group"

echo ""
echo "12. AWS IDENTITY"
check "aws sts get-caller-identity" "AWS Configured"

echo ""
echo "13. ECR REPO"
check "aws ecr describe-repositories --repository-names springboot-jenkins-ecr-repo --region us-east-2" "ECR Exists"

echo ""
echo "14. EKS CLUSTER"
check "aws eks describe-cluster --name jenkins-cluster --region us-east-2" "EKS Exists"

echo ""
echo "15. NODEGROUP"
check "aws eks describe-nodegroup --cluster-name jenkins-cluster --nodegroup-name jenkins-nodegroup --region us-east-2" "Nodegroup Exists"

echo ""
echo "16. K8S NODES"
check "kubectl get nodes" "Kubernetes Nodes Ready"

echo ""
echo "======================================"
echo "SCORE"
echo "======================================"

echo "$PASS / $TOTAL"

echo ""
echo "======================================"
echo "DETAILS"
echo "======================================"

echo "Docker Version:"
docker --version || true

echo ""
echo "eksctl:"
eksctl version || true

echo ""
echo "Jenkins:"
systemctl is-active jenkins || true

echo ""
echo "Volumes:"
docker volume ls || true

echo ""
echo "Networks:"
docker network ls || true
