#!/bin/bash

set -e

echo "=================================="
echo "SYSTEM UPDATE"
echo "=================================="

sudo apt update -y

echo "=================================="
echo "JAVA"
echo "=================================="

sudo apt install -y default-jdk

echo "=================================="
echo "TOOLS"
echo "=================================="

sudo apt install -y 
curl 
wget 
git 
unzip 
jq 
maven

echo "=================================="
echo "AWS CLI V2"
echo "=================================="

curl -s "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o awscliv2.zip
unzip -q awscliv2.zip
sudo ./aws/install

echo "=================================="
echo "DOCKER"
echo "=================================="

sudo apt install -y docker.io

sudo systemctl enable docker
sudo systemctl start docker

echo "=================================="
echo "KUBECTL"
echo "=================================="

curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"

chmod +x kubectl
sudo mv kubectl /usr/local/bin/

echo "=================================="
echo "EKSCTL"
echo "=================================="

ARCH=amd64
PLATFORM=$(uname -s)_$ARCH

curl -sLO https://github.com/eksctl-io/eksctl/releases/latest/download/eksctl_${PLATFORM}.tar.gz

tar -xzf eksctl_${PLATFORM}.tar.gz -C /tmp

sudo mv /tmp/eksctl /usr/local/bin

echo "=================================="
echo "JENKINS"
echo "=================================="

curl -fsSL https://pkg.jenkins.io/debian-stable/jenkins.io-2023.key | 
sudo tee /usr/share/keyrings/jenkins-keyring.asc >/dev/null

echo deb 
[signed-by=/usr/share/keyrings/jenkins-keyring.asc] 
https://pkg.jenkins.io/debian-stable binary/ | 
sudo tee /etc/apt/sources.list.d/jenkins.list >/dev/null

sudo apt update -y
sudo apt install -y jenkins

sudo systemctl enable jenkins
sudo systemctl start jenkins

echo "=================================="
echo "JENKINS DOCKER ACCESS"
echo "=================================="

sudo usermod -aG docker jenkins
sudo usermod -aG docker ubuntu

echo "=================================="
echo "LAB REQUIREMENTS"
echo "=================================="

sudo docker volume create jenkins_data || true
sudo docker network create jenkins_network || true

sudo systemctl restart docker
sudo systemctl restart jenkins

echo "=================================="
echo "VALIDATION"
echo "=================================="

java -version
aws --version
docker --version
kubectl version --client
eksctl version
mvn -version

echo ""
echo "Jenkins Service:"
systemctl is-active jenkins

echo ""
echo "Docker Volume:"
docker volume ls | grep jenkins_data

echo ""
echo "Docker Network:"
docker network ls | grep jenkins_network

echo ""
echo "=================================="
echo "JENKINS PASSWORD"
echo "=================================="

sudo cat /var/lib/jenkins/secrets/initialAdminPassword
