#!/bin/bash

echo "=================================="
echo "IAM ROLE CHECK"
echo "=================================="
aws iam get-role --role-name ec2-eks-role --query 'Role.RoleName' --output text

echo ""
echo "=================================="
echo "SECURITY GROUP CHECK"
echo "=================================="
aws ec2 describe-security-groups \
--filters "Name=group-name,Values=jenkins-server-security-group" \
--query 'SecurityGroups[*].[GroupName,GroupId,VpcId]' \
--output table

echo ""
echo "=================================="
echo "EC2 CHECK"
echo "=================================="
aws ec2 describe-instances \
--filters "Name=tag:Name,Values=jenkins-server" \
"Name=instance-state-name,Values=running,pending" \
--query 'Reservations[*].Instances[*].[InstanceId,InstanceType,State.Name,PrivateIpAddress]' \
--output table

echo ""
echo "=================================="
echo "SUMMARY"
echo "=================================="
echo "Expected:"
echo "Role = ec2-eks-role"
echo "Security Group = jenkins-server-security-group"
echo "EC2 Name = jenkins-server"
echo "EC2 Type = t3.small"
