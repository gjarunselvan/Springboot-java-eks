#!/bin/bash

PASS=0
TOTAL=8

echo "=========================================="
echo "      JENKINS + EKS LAB VALIDATION"
echo "=========================================="

echo ""
echo "1. EC2 INSTANCE (jenkins-server)"
EC2=$(aws ec2 describe-instances \
--filters "Name=tag:Name,Values=jenkins-server" \
"Name=instance-state-name,Values=running" \
--query 'Reservations[*].Instances[*].InstanceId' \
--output text 2>/dev/null)

if [ -n "$EC2" ]; then
    echo "PASS - jenkins-server found"
    PASS=$((PASS+1))
else
    echo "FAIL - jenkins-server not found"
fi

echo ""
echo "2. IAM ROLE (ec2-eks-role)"
aws iam get-role --role-name ec2-eks-role >/dev/null 2>&1
if [ $? -eq 0 ]; then
    echo "PASS - ec2-eks-role found"
    PASS=$((PASS+1))
else
    echo "FAIL - ec2-eks-role missing"
fi

echo ""
echo "3. SECURITY GROUP (jenkins-server-security-group)"
SG=$(aws ec2 describe-security-groups \
--filters Name=group-name,Values=jenkins-server-security-group \
--query 'SecurityGroups[*].GroupName' \
--output text 2>/dev/null)

if [ "$SG" = "jenkins-server-security-group" ]; then
    echo "PASS - Security Group found"
    PASS=$((PASS+1))
else
    echo "FAIL - Security Group missing"
fi

echo ""
echo "4. JENKINS"
if systemctl is-active --quiet jenkins; then
    echo "PASS - Jenkins running"
    PASS=$((PASS+1))
else
    echo "FAIL - Jenkins not running"
fi

echo ""
echo "5. DOCKER VOLUME (jenkins_data)"
if docker volume ls | grep -q "jenkins_data"; then
    echo "PASS - jenkins_data exists"
    PASS=$((PASS+1))
else
    echo "FAIL - jenkins_data missing"
fi

echo ""
echo "6. DOCKER NETWORK (jenkins_network)"
if docker network ls | grep -q "jenkins_network"; then
    echo "PASS - jenkins_network exists"
    PASS=$((PASS+1))
else
    echo "FAIL - jenkins_network missing"
fi

echo ""
echo "7. ECR REPOSITORY (springboot-jenkins-ecr-repo)"
aws ecr describe-repositories \
--repository-names springboot-jenkins-ecr-repo \
--region us-east-2 >/dev/null 2>&1

if [ $? -eq 0 ]; then
    echo "PASS - ECR exists"
    PASS=$((PASS+1))
else
    echo "FAIL - ECR missing"
fi

echo ""
echo "8. EKS CLUSTER + NODEGROUP"
aws eks describe-cluster \
--name jenkins-cluster \
--region us-east-2 >/dev/null 2>&1

CLUSTER=$?

aws eks describe-nodegroup \
--cluster-name jenkins-cluster \
--nodegroup-name jenkins-nodegroup \
--region us-east-2 >/dev/null 2>&1

NODEGROUP=$?

if [ $CLUSTER -eq 0 ] && [ $NODEGROUP -eq 0 ]; then
    echo "PASS - EKS + Nodegroup found"
    PASS=$((PASS+1))
else
    echo "FAIL - EKS or Nodegroup missing"
fi

echo ""
echo "=========================================="
echo "RESULT: $PASS / $TOTAL"
echo "=========================================="

if [ $PASS -eq $TOTAL ]; then
    echo "LAB READY FOR SUBMISSION"
else
    echo "COMPLETE REMAINING FAILED ITEMS"
fi
