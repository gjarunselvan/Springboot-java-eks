#!/bin/bash

echo "=================================="
echo "DISABLE JENKINS SECURITY"
echo "=================================="

cp /home/ubuntu/.jenkins/config.xml \
/home/ubuntu/.jenkins/config.xml.bak

sed -i 's/<useSecurity>true<\/useSecurity>/<useSecurity>false<\/useSecurity>/g' \
/home/ubuntu/.jenkins/config.xml

echo ""
echo "VERIFY"
grep useSecurity /home/ubuntu/.jenkins/config.xml

echo ""
echo "RESTART JENKINS"

sudo pkill -9 -f jenkins.war || true

sleep 5

sudo su - jenkins -c "
JENKINS_HOME=/home/ubuntu/.jenkins \
nohup java \
-DJENKINS_HOME=/home/ubuntu/.jenkins \
-jar /home/jenkins/jenkins/jenkins.war \
--httpPort=8080 \
>/tmp/jenkins.log 2>&1 &
"

echo ""
echo "WAIT 45 SECONDS..."
sleep 45

echo ""
echo "PROCESS"
ps -ef | grep jenkins.war | grep -v grep

echo ""
echo "WEB"
curl -I http://localhost:8080 | head -5

echo ""
echo "=================================="
echo "DONE"
echo "=================================="
echo "Open Jenkins now."
echo "It should not ask for login."
