#!/bin/bash

echo "=================================="
echo "ECR PERMISSION CHECK"
echo "=================================="

echo ""
echo "1. AWS IDENTITY"
aws sts get-caller-identity

echo ""
echo "2. EC2 IAM ROLE"
curl -s http://169.254.169.254/latest/meta-data/iam/security-credentials/

echo ""
echo "3. ATTACHED POLICIES"
aws iam list-attached-role-policies \
--role-name ec2-eks-role

echo ""
echo "4. INLINE POLICIES"
aws iam list-role-policies \
--role-name ec2-eks-role

echo ""
echo "5. ECR REPOSITORY"
aws ecr describe-repositories \
--repository-names springboot-jenkins-ecr-repo \
--region us-east-2

echo ""
echo "6. ECR PUSH TEST"
aws ecr get-login-password \
--region us-east-2 | head -c 10

echo ""
echo ""
echo "=================================="
echo "DONE"
echo "=================================="
