#!/bin/bash

echo "=================================="
echo "FIX DOCKER FOR JENKINS PIPELINE"
echo "=================================="

echo ""
echo "1. CURRENT USER"
whoami

echo ""
echo "2. ADD UBUNTU TO DOCKER GROUP"
sudo usermod -aG docker ubuntu

echo ""
echo "3. REFRESH GROUP"
newgrp docker <<EOF

echo ""
echo "4. VERIFY DOCKER ACCESS"
docker ps

echo ""
echo "5. VERIFY DOCKER BUILD"
docker images

EOF

echo ""
echo "6. RESTART JENKINS"
pkill -f jenkins.war || true

nohup java -jar ~/jenkins/jenkins.war \
--httpPort=8080 \
> ~/jenkins/jenkins.log 2>&1 &

echo ""
echo "WAITING 30 SECONDS..."
sleep 30

echo ""
echo "7. VERIFY JENKINS"
curl -I http://localhost:8080 | head -5

echo ""
echo "=================================="
echo "READY"
echo "=================================="
echo "Go to Jenkins -> Build Now"
