#!/bin/bash

echo "=================================="
echo "FIX JENKINS HOME PERMISSIONS"
echo "=================================="

sudo chown -R jenkins:jenkins /home/ubuntu/.jenkins

sudo chmod -R u+rwX /home/ubuntu/.jenkins

echo ""
echo "START JENKINS"

sudo su - jenkins -c "
export JENKINS_HOME=/home/ubuntu/.jenkins
nohup java \
-DJENKINS_HOME=/home/ubuntu/.jenkins \
-jar /home/jenkins/jenkins/jenkins.war \
--httpPort=8080 \
>/tmp/jenkins.log 2>&1 &
"

echo ""
echo "WAIT 30 SECONDS"
sleep 30

echo ""
echo "PROCESS"
ps -ef | grep jenkins.war | grep -v grep

echo ""
echo "PORT"
ss -tulpn | grep 8080

echo ""
echo "LOG"
tail -50 /tmp/jenkins.log

echo ""
echo "DONE"
