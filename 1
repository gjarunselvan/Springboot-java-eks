#!/bin/bash

echo "=================================="
echo "CREATE JENKINS DIRECTORY"
echo "=================================="

mkdir -p $HOME/jenkins

echo ""
echo "=================================="
echo "DOWNLOAD JENKINS"
echo "=================================="

cd $HOME/jenkins

curl -L -o jenkins.war \
https://get.jenkins.io/war-stable/latest/jenkins.war

echo ""
echo "=================================="
echo "START JENKINS"
echo "=================================="

nohup java -jar $HOME/jenkins/jenkins.war \
--httpPort=8080 \
> $HOME/jenkins/jenkins.log 2>&1 &

echo ""
echo "WAITING 60 SECONDS..."
sleep 60

echo ""
echo "=================================="
echo "PROCESS CHECK"
echo "=================================="

ps -ef | grep jenkins.war

echo ""
echo "=================================="
echo "PORT CHECK"
echo "=================================="

ss -tulpn | grep 8080

echo ""
echo "=================================="
echo "HTTP CHECK"
echo "=================================="

curl -I http://localhost:8080

echo ""
echo "=================================="
echo "LAST 20 LOG LINES"
echo "=================================="

tail -20 $HOME/jenkins/jenkins.log

echo ""
echo "=================================="
echo "EKS STATUS"
echo "=================================="

aws eks describe-cluster \
--name jenkins-cluster \
--region us-east-2 \
--query 'cluster.status' \
--output text

echo ""
echo "=================================="
echo "DONE"
echo "=================================="
