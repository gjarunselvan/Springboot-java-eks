#!/bin/bash

echo "=================================="
echo "JENKINS USER CHECK"
echo "=================================="

ps -ef | grep jenkins | grep -v grep

echo ""
echo "=================================="
echo "JENKINS ACCOUNT"
echo "=================================="

id jenkins

echo ""
echo "=================================="
echo "ADD JENKINS TO DOCKER GROUP"
echo "=================================="

sudo usermod -aG docker jenkins

echo ""
echo "=================================="
echo "VERIFY GROUPS"
echo "=================================="

groups jenkins

echo ""
echo "=================================="
echo "TEST DOCKER AS JENKINS"
echo "=================================="

sudo su - jenkins -c "docker ps"

echo ""
echo "=================================="
echo "DOCKER SOCKET"
echo "=================================="

ls -l /var/run/docker.sock

echo ""
echo "=================================="
echo "RESULT"
echo "=================================="

echo "If docker ps works above,"
echo "go to Jenkins -> Build Now"
