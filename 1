#!/bin/bash

echo "=================================="
echo "LAB VALIDATION"
echo "=================================="

echo ""
echo "1. AWS IDENTITY"
aws sts get-caller-identity

echo ""
echo "2. IAM ROLE"

ROLE=$(aws sts get-caller-identity --query Arn --output text 2>/dev/null)

echo "$ROLE"

if echo "$ROLE" | grep -q "assumed-role"; then
echo "PASS"
else
echo "FAIL"
fi

echo ""
echo "3. INSTANCE TYPE"

TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")

TYPE=$(curl -s -H "X-aws-ec2-metadata-token: $TOKEN" http://169.254.169.254/latest/meta-data/instance-type)

echo "$TYPE"

if [ "$TYPE" = "t3.small" ]; then
echo "PASS"
else
echo "FAIL"
fi

echo ""
echo "4. JENKINS"

systemctl is-active jenkins || true

echo ""
echo "5. JENKINS USER"

id jenkins || true

echo ""
echo "6. DOCKER GROUP"

groups jenkins || true

echo ""
echo "7. DOCKER VOLUME"

sudo docker volume ls

echo ""
echo "8. DOCKER NETWORK"

sudo docker network ls

echo ""
echo "=================================="
echo "SUMMARY"
echo "=================================="

echo "If Jenkins inactive -> install Jenkins"
echo "If jenkins user missing -> Jenkins not installed"
echo "If jenkins_data missing -> create volume"
echo "If jenkins_network missing -> create network"
