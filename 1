#!/bin/bash

echo "====================================="
echo "PHASE 1 + PHASE 2 VALIDATION"
echo "====================================="

echo ""
echo "===== JAVA ====="
java -version | head -1

echo ""
echo "===== AWS CLI ====="
aws --version

echo ""
echo "===== KUBECTL ====="
kubectl version --client

echo ""
echo "===== EKSCTL ====="
eksctl version

echo ""
echo "===== DOCKER ====="
docker --version

echo ""
echo "===== JENKINS ====="
systemctl is-active jenkins

echo ""
echo "===== IAM ROLE ====="
aws iam get-role --role-name ec2-eks-role \
--query 'Role.RoleName' \
--output text

echo ""
echo "===== SECURITY GROUP ====="
aws ec2 describe-security-groups \
--filters Name=group-name,Values=jenkins-server-security-group \
--query 'SecurityGroups[*].GroupName' \
--output text

echo ""
echo "===== EC2 ====="
aws ec2 describe-instances \
--filters Name=instance-state-name,Values=running \
--query 'Reservations[*].Instances[*].[Tags[?Key==`Name`].Value|[0],InstanceType]' \
--output table
