#!/bin/bash

REGION="us-east-2"

echo "=================================="
echo "STEP 1 - DOCKER VOLUME"
echo "=================================="

docker volume create jenkins_data || true

echo ""
echo "=================================="
echo "STEP 2 - DOCKER NETWORK"
echo "=================================="

docker network create jenkins_network || true

echo ""
echo "=================================="
echo "STEP 3 - VERIFY DOCKER"
echo "=================================="

docker volume ls | grep jenkins

docker network ls | grep jenkins

echo ""
echo "=================================="
echo "STEP 4 - CREATE ECR"
echo "=================================="

aws ecr describe-repositories \
--repository-names springboot-jenkins-ecr-repo \
--region $REGION >/dev/null 2>&1

if [ $? -eq 0 ]; then
    echo "ECR already exists"
else
    aws ecr create-repository \
    --repository-name springboot-jenkins-ecr-repo \
    --region $REGION
fi

echo ""
echo "=================================="
echo "STEP 5 - VERIFY ECR"
echo "=================================="

aws ecr describe-repositories \
--repository-names springboot-jenkins-ecr-repo \
--region $REGION \
--query 'repositories[*].repositoryName' \
--output text

echo ""
echo "=================================="
echo "STEP 6 - CREATE EKS CLUSTER"
echo "=================================="

eksctl create cluster \
--name jenkins-cluster \
--region us-east-2 \
--nodegroup-name jenkins-nodegroup \
--node-type t3.medium \
--nodes 2

echo ""
echo "=================================="
echo "STEP 7 - VERIFY"
echo "=================================="

aws eks list-clusters --region us-east-2

kubectl get nodes

echo ""
echo "=================================="
echo "DONE"
echo "=================================="
