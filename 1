#!/bin/bash

echo "=================================="
echo "RESTORE OLD JENKINS HOME"
echo "=================================="

pkill -9 -f jenkins.war || true

sleep 5

echo ""
echo "VERIFY OLD HOME"
ls -ld /home/ubuntu/.jenkins

echo ""
echo "START JENKINS WITH OLD HOME"

sudo su - jenkins -c "
JENKINS_HOME=/home/ubuntu/.jenkins \
nohup java -DJENKINS_HOME=/home/ubuntu/.jenkins \
-jar /home/jenkins/jenkins/jenkins.war \
--httpPort=8080 \
>/tmp/jenkins.log 2>&1 &
"

echo ""
echo "WAIT 45 SECONDS"
sleep 45

echo ""
echo "PROCESS"
ps -ef | grep jenkins.war | grep -v grep

echo ""
echo "WEB"
curl -I http://localhost:8080 | head -5

echo ""
echo "CHECK JOBS"
ls /home/ubuntu/.jenkins/jobs

echo ""
echo "CHECK USERS"
ls /home/ubuntu/.jenkins/users

echo ""
echo "DONE"
