#!/bin/bash

echo "=================================="
echo "DISK BEFORE"
echo "=================================="
df -h

echo ""
echo "=================================="
echo "CLEAN APT CACHE"
echo "=================================="
sudo apt clean

echo ""
echo "=================================="
echo "CLEAN TMP"
echo "=================================="
sudo rm -rf /tmp/*
sudo rm -rf /var/tmp/*

echo ""
echo "=================================="
echo "CLEAN DOCKER"
echo "=================================="
sudo docker system prune -af
sudo docker volume prune -f

echo ""
echo "=================================="
echo "CHECK JENKINS DIRECTORY"
echo "=================================="
mkdir -p $HOME/jenkins

if [ ! -f $HOME/jenkins/jenkins.war ]; then
    echo "Downloading Jenkins..."
    cd $HOME/jenkins
    curl -L -o jenkins.war https://get.jenkins.io/war-stable/latest/jenkins.war
fi

echo ""
echo "=================================="
echo "START JENKINS"
echo "=================================="
pkill -f jenkins.war || true

nohup java -jar $HOME/jenkins/jenkins.war \
--httpPort=8080 \
> $HOME/jenkins/jenkins.log 2>&1 &

echo ""
echo "WAIT 60 SECONDS..."
sleep 60

echo ""
echo "=================================="
echo "JENKINS CHECK"
echo "=================================="
ps -ef | grep jenkins.war

echo ""
ss -tulpn | grep 8080

echo ""
curl -I http://localhost:8080 | head -5

echo ""
echo "=================================="
echo "TOOLS CHECK"
echo "=================================="
which docker
which aws
which kubectl

docker --version
aws --version
kubectl version --client

echo ""
echo "=================================="
echo "DISK AFTER"
echo "=================================="
df -h

echo ""
echo "=================================="
echo "DONE"
echo "=================================="
