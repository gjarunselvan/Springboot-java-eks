#!/bin/bash

echo "===== DOWNLOAD JENKINS ====="

cd /tmp

curl -L -o jenkins.war \
https://get.jenkins.io/war-stable/latest/jenkins.war

echo ""
echo "===== START JENKINS ====="

nohup java -jar /tmp/jenkins.war \
--httpPort=8080 \
> /tmp/jenkins.log 2>&1 &

echo ""
echo "===== WAIT 60 SECONDS ====="

sleep 60

echo ""
echo "===== PROCESS CHECK ====="

ps -ef | grep jenkins.war

echo ""
echo "===== PORT CHECK ====="

ss -tulpn | grep 8080

echo ""
echo "===== JENKINS URL ====="

curl -I http://localhost:8080

echo ""
echo "===== ADMIN PASSWORD ====="

find ~/.jenkins -name initialAdminPassword -exec cat {} \; 2>/dev/null

echo ""
echo "===== DONE ====="
